{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stoneturner",
  "fonts": {
    "family": "Inter"
  },
  "colors": {
    "primary": "#898ED3",
    "light": "#898ED3",
    "dark": "#898ED3"
  },
  "background": {
    "color": {
      "light": "#f5f5f5",
      "dark": "#262626"
    }
  },
  "favicon": "/assets/favicon.ico",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "overview",
          "quickstart",
          "how-stoneturner-works"
        ]
      },
      {
        "group": "For Builders",
        "pages": [
          "architecture",
          "add-integrations"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          {
          "group":  "Supported Data Sources",
            "pages": [
              "data/gong",
              "data/discord",
              "data/notion",
              "data/plaud",
              "data/firecrawl"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Connect to Stoneturner MCP",
          "icon": "square-terminal",
          "href": "https://app.stoneturner.app"
        }
      ]
    }
  },
  "logo": {
    "light": "/assets/stoneturner.png",
    "dark": "/assets/stoneturner.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "github",
      "label": "Stoneturner",
      "href": "https://github.com/jackmuva/stoneturner"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
